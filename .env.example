# Anthropic Claude API — required for real recommendations
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Firecrawl API — required for live Etsy data
# https://www.firecrawl.dev/app
FIRECRAWL_API_KEY=

# Optional — Vercel KV for production cache (replace in-memory cache)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Public site origin used when building absolute share URLs (Pinterest, copy-link).
# Without this set, share URLs fall back to the request origin in the browser
# and to http://localhost:3000 on the server.
NEXT_PUBLIC_SITE_URL=https://nichefinder.io
